# Munin self-host environment.
# Copy to .env and fill in values.

# --- Postgres -----------------------------------------------------------
POSTGRES_USER=munin
POSTGRES_PASSWORD=munin
POSTGRES_DB=munin
POSTGRES_PORT=5432

# --- Backend ------------------------------------------------------------
BACKEND_PORT=3001
MUNIN_MCP_URL=http://localhost:3001
# Generate with: openssl rand -base64 48
MUNIN_AUTH_SECRET=replace-me-with-strong-random-secret

# --- Web ----------------------------------------------------------------
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
MUNIN_AUTH_SECRET=dev-secret-do-not-use-in-prod
