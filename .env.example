# Munin self-host environment.
# Copy to .env and fill in values.

# --- Postgres -----------------------------------------------------------
# Used by docker compose to provision the container.
POSTGRES_USER=munin
POSTGRES_PASSWORD=munin
POSTGRES_DB=munin
POSTGRES_PORT=5432

# --- Migrations (superuser) --------------------------------------------
# Runs CREATE EXTENSION + DDL + creates the munin_app role.
# In production, use the database admin role provided by your host.
MUNIN_MIGRATE_URL=postgres://munin:munin@localhost:5432/munin

# --- App connection (non-superuser, RLS-bound) -------------------------
# The application uses this URL for normal traffic. The migration runner
# creates the munin_app role with restricted privileges so Postgres RLS
# policies actually apply (superusers bypass RLS, regardless of FORCE).
DATABASE_URL=postgres://munin_app:munin_app@localhost:5432/munin

# --- Backend ------------------------------------------------------------
BACKEND_PORT=3001
MUNIN_PUBLIC_URL=http://localhost:3001
# Generate with: openssl rand -base64 48
MUNIN_AUTH_SECRET=replace-me-with-strong-random-secret
# Used to pepper API-key hashes; rotate it and you invalidate every key.
MUNIN_KEY_PEPPER=replace-me-with-strong-random-pepper
# Comma-separated origins permitted to call /auth (CSRF/CORS). Defaults to
# localhost:3000 for dev. Set this to your dashboard URL in production
# (e.g. https://getmunin.com,https://app.getmunin.com).
MUNIN_AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Signup gating -----------------------------------------------------
# Munin is single-tenant: the first user to sign up becomes the admin of
# the singleton org; subsequent users must arrive via an invitation token
# or via an email whose domain is in MUNIN_ALLOWED_EMAIL_DOMAINS. Empty
# allowlist = invite-only.
# Example: MUNIN_ALLOWED_EMAIL_DOMAINS=example.com,acme.io
MUNIN_ALLOWED_EMAIL_DOMAINS=

# --- Asset storage (CMS media library) ---------------------------------
# `local` writes to MUNIN_STORAGE_LOCAL_PATH and serves through the
# backend's /static/assets handler — fine for `docker compose up` self-host.
# `s3` uploads go to any S3-compatible service (Scaleway Object Storage,
# AWS S3, Cloudflare R2, MinIO) via SigV4 presigned URLs.
MUNIN_STORAGE_PROVIDER=local
MUNIN_STORAGE_LOCAL_PATH=/var/munin/assets
MUNIN_STORAGE_LOCAL_BASE_URL=http://localhost:3001/static/assets
# Strong random secret used to sign local upload URLs; rotate it and
# in-flight upload URLs are immediately invalidated.
MUNIN_STORAGE_LOCAL_SECRET=replace-me-with-strong-random-secret
# S3 mode (only used when MUNIN_STORAGE_PROVIDER=s3):
MUNIN_STORAGE_S3_BUCKET=
MUNIN_STORAGE_S3_REGION=fr-par
MUNIN_STORAGE_S3_ENDPOINT=https://s3.fr-par.scw.cloud
MUNIN_STORAGE_S3_ACCESS_KEY=
MUNIN_STORAGE_S3_SECRET_KEY=
# Optional CDN / public-read URL for objects (defaults to the S3 endpoint).
MUNIN_STORAGE_S3_PUBLIC_BASE_URL=

# --- Web app URL (for email links) -------------------------------------
# Used to build verification + reset + partner-owner-claim links.
MUNIN_WEB_URL=http://localhost:3000

# --- Transactional email (optional, defaults to in-memory stub) --------
# Set MUNIN_MAIL_PROVIDER=resend + RESEND_API_KEY to send real emails.
# https://resend.com/api-keys
MUNIN_MAIL_PROVIDER=stub
RESEND_API_KEY=
MUNIN_MAIL_FROM=Munin <no-reply@getmunin.com>

# --- Embedding provider (optional, defaults to deterministic stub) -----
# Set OPENAI_API_KEY to use OpenAI text-embedding-3-small.
# Or point OPENAI_BASE_URL at a local LM Studio / vLLM / llama.cpp server
# that speaks the OpenAI protocol for fully-local embeddings.
OPENAI_API_KEY=
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Google Sign-in (optional) -----------------------------------------
# https://console.cloud.google.com/apis/credentials → OAuth 2.0 Client ID
# Authorized redirect URI: <MUNIN_PUBLIC_URL>/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Web ----------------------------------------------------------------
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
