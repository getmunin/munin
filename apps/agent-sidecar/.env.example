# Munin instance the sidecar talks to.
MUNIN_BASE_URL=http://localhost:3001

# Admin API key (mn_admin_…) used to subscribe to the realtime gateway,
# fetch conversation history, mint delegated end-user tokens, post the
# agent's final reply, seed/read prompt documents in the KB, and run
# curator skill passes.
MUNIN_ADMIN_API_KEY=

# OpenAI-compatible LLM provider. Defaults to OpenRouter; point at OpenAI,
# a self-hosted Ollama, vLLM, etc. by overriding the base URL.
MUNIN_SIDECAR_PROVIDER_BASE_URL=https://openrouter.ai/api/v1
MUNIN_SIDECAR_PROVIDER_API_KEY=

# Model to use. For OpenRouter, this is the slug they document
# (https://openrouter.ai/models).
MUNIN_SIDECAR_MODEL=anthropic/claude-haiku-4.5

# Wait this many ms after the last user message before generating, so
# multi-message bursts collapse into one reply.
MUNIN_SIDECAR_DEBOUNCE_MS=500

# Hard cap on the LLM ↔ tool-call loop iterations per turn.
MUNIN_SIDECAR_MAX_TOOL_ITERATIONS=8

# Soft cap on how many characters of conversation history get sent to the
# LLM. Oldest turns drop first; the model is told context was elided so it
# doesn't fabricate detail. ~4 chars per token, so 32k chars ≈ 8k tokens.
MUNIN_SIDECAR_MAX_HISTORY_CHARS=32000

# Override the directory the sidecar reads canonical prompt defaults from
# on first boot. The shipped defaults live in the package's prompts/
# directory next to dist/; override only if you want a custom seed source
# without rebuilding the image. Once seeded into the KB, edits live in
# munin (kb_documents in space `agent-runtime`) and disk is unused.
# MUNIN_SIDECAR_PROMPTS_DIR=/etc/munin/agent-prompts

# Curator worker paths. Defaults: KB curation runs per-handover, all sweep
# cadences are owned by the backend's @nestjs/schedule cron jobs (see
# MUNIN_CURATOR_*_CRON in the backend's env). Set CURATORS_DISABLED=1 here
# to make the sidecar stop draining the queue; the backend keeps enqueueing.
MUNIN_SIDECAR_CURATORS_DISABLED=0
MUNIN_SIDECAR_KB_CURATION_ON_HANDOVER=1
