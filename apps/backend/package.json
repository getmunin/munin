{
  "name": "@getmunin/backend",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "prebuild": "node scripts/copy-widget.mjs && node scripts/copy-tracker.mjs",
    "build": "nest build",
    "dev": "node --import @swc-node/register/esm-register --watch --conditions=development src/main.ts",
    "start": "node dist/main.js",
    "migrate": "node --import @swc-node/register/esm-register --conditions=development src/migrate.ts",
    "migrate:test": "node --import @swc-node/register/esm-register --conditions=development src/migrate-test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@better-auth/oauth-provider": "^1.6.23",
    "@getmunin/agent-host": "workspace:*",
    "@getmunin/analytics-tracker": "workspace:*",
    "@getmunin/backend-core": "workspace:*",
    "@getmunin/chat-widget": "workspace:*",
    "@getmunin/core": "workspace:*",
    "@getmunin/db": "workspace:*",
    "@getmunin/emails": "workspace:*",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@sentry/nestjs": "^10.51.0",
    "@sentry/profiling-node": "^10.51.0",
    "better-auth": "^1.6.11",
    "drizzle-orm": "^0.45.2",
    "express": "^5.1.0",
    "postgres": "^3.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@getmunin/eslint-config": "workspace:*",
    "@getmunin/tsconfig": "workspace:*",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/testing": "^11.1.19",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.41",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.0",
    "eslint": "^9.10.0",
    "supertest": "^7.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.9"
  }
}
