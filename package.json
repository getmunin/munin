{
  "name": "munin",
  "version": "0.0.1",
  "private": true,
  "description": "MCP-first customer platform made for the agentic era (Knowledge Base, Conversations, CRM, CMS, Outreach)",
  "license": "MIT",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test --concurrency=1",
    "test:coverage": "node scripts/coverage.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "licenses:check": "node scripts/licenses.mjs check",
    "licenses:generate": "node scripts/licenses.mjs generate",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm -r --filter '@getmunin/*' --filter '!@getmunin/eslint-config' --filter '!@getmunin/tsconfig' --filter '!@getmunin/backend' --filter '!@getmunin/web' build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "turbo": "^2.9.18",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.61.1"
  },
  "pnpm": {
    "overrides": {
      "multer": "^2.2.0",
      "glob": "^10.5.0",
      "picomatch": "^4.0.4",
      "ajv@>=7": "^8.18.0",
      "postcss": "^8.5.10",
      "vite": "^6.4.3",
      "file-type": "^21.3.2",
      "esbuild": "^0.28.1",
      "webpack": "^5.104.1",
      "tmp": "^0.2.4",
      "hono": "^4.12.25",
      "ip-address": "^10.2.0",
      "fast-uri": "^3.1.2",
      "kysely": "^0.28.17",
      "ws": "^8.21.0",
      "brace-expansion@>=5.0.0 <5.0.6": "^5.0.6",
      "qs": ">=6.15.2",
      "next-intl": "^4.13.0",
      "vitest": "^4.1.0",
      "form-data@>=4.0.0 <4.0.6": "^4.0.6",
      "@opentelemetry/core": "^2.8.0",
      "@babel/core@>=7 <8": "^7.29.6",
      "js-yaml@>=4 <4.2.0": "^4.2.0",
      "read-yaml-file@1": "^2.1.0",
      "nodemailer@<9.0.1": "^9.0.1"
    }
  }
}
