{
  "name": "@getmunin/backend-core",
  "version": "4.67.2",
  "license": "MIT",
  "description": "Shared NestJS modules powering both OSS and cloud Munin backends.",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/getmunin/munin.git",
    "directory": "packages/backend-core"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./docs-fixtures/mcp-tools.json": "./docs-fixtures/mcp-tools.json",
    "./docs-fixtures/skills.json": "./docs-fixtures/skills.json",
    "./openapi.json": "./openapi.json"
  },
  "files": [
    "dist",
    "src",
    "docs-fixtures",
    "openapi.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ./scripts/copy-skills.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "openapi:generate": "node --import @swc-node/register/esm-register ./scripts/generate-openapi.ts",
    "docs:generate": "pnpm openapi:generate && node --import @swc-node/register/esm-register ./scripts/generate-docs-fixtures.ts",
    "mcp:sweep": "node --import @swc-node/register/esm-register ./scripts/mcp-sweep.ts"
  },
  "dependencies": {
    "@better-auth/oauth-provider": "^1.6.10",
    "@getmunin/agent-runtime": "workspace:*",
    "@getmunin/core": "workspace:*",
    "@getmunin/db": "workspace:*",
    "@getmunin/emails": "workspace:*",
    "@getmunin/inspector-app": "workspace:*",
    "@getmunin/mcp-toolkit": "workspace:*",
    "@getmunin/types": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/throttler": "^6.0.0",
    "better-auth": "^1.6.13",
    "cron": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "express": "^5.1.0",
    "imapflow": "^1.3.2",
    "jose": "^6.0.0",
    "mailparser": "^3.9.8",
    "marked": "^18.0.3",
    "maxmind": "^5.0.0",
    "nodemailer": "^9.0.1",
    "postgres": "^3.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ws": "^8.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@getmunin/eslint-config": "workspace:*",
    "@getmunin/tsconfig": "workspace:*",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.41",
    "@types/express": "^5.0.0",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.7.0",
    "@types/nodemailer": "^8.0.1",
    "@types/ws": "^8.5.13",
    "eslint": "^9.10.0",
    "typescript": "^5.6.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.9"
  }
}
