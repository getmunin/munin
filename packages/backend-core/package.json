{
  "name": "@getmunin/backend-core",
  "version": "2.5.1",
  "license": "MIT",
  "description": "Shared NestJS modules powering both OSS and cloud Munin backends.",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/getmunin/munin.git",
    "directory": "packages/backend-core"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ./scripts/copy-skills.mjs",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@getmunin/bootstrap": "workspace:*",
    "@getmunin/core": "workspace:*",
    "@getmunin/db": "workspace:*",
    "@getmunin/mcp-toolkit": "workspace:*",
    "@getmunin/types": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/throttler": "^6.0.0",
    "better-auth": "^1.1.0",
    "cron": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "express": "^5.1.0",
    "imapflow": "^1.3.2",
    "mailparser": "^3.9.8",
    "nodemailer": "^8.0.7",
    "postgres": "^3.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@getmunin/eslint-config": "workspace:*",
    "@getmunin/tsconfig": "workspace:*",
    "@swc/core": "^1.15.32",
    "@types/express": "^5.0.0",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.7.0",
    "@types/nodemailer": "^8.0.0",
    "@types/ws": "^8.5.13",
    "eslint": "^9.10.0",
    "typescript": "^5.6.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^2.1.0"
  }
}
