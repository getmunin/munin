{
  "name": "@getmunin/ui",
  "version": "4.15.0",
  "license": "MIT",
  "description": "Munin design-system primitives (shadcn-style) shared between OSS and cloud Next apps.",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/getmunin/munin.git",
    "directory": "packages/ui"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
